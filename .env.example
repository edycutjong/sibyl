# ──────────────────────────────────────────────────────────────
# Sibyl — Environment Variables
# ──────────────────────────────────────────────────────────────

# Prophet Arena (required for server registration + submission)
PA_SERVER_API_KEY=your_prophet_arena_api_key
PA_SERVER_URL=https://api.aiprophet.dev

# LLM Providers (at least one required)
OPENAI_API_KEY=sk-...                  # GPT-4o-mini (classification + high-confidence)
ANTHROPIC_API_KEY=sk-ant-...           # Claude Sonnet 4 (low-confidence reasoning)
GOOGLE_API_KEY=AIza...                 # Gemini 2.5 Flash (medium-confidence)

# Search / Retrieval (at least one required)
EXA_API_KEY=your_exa_api_key           # Exa search (recommended)
BRAVE_API_KEY=                         # Brave search (alternative)

# Agent Endpoint Auth
BEARER_TOKEN=sibyl-secret-token        # Token for your deployed endpoint

# Optional
LOG_LEVEL=INFO
CACHE_DIR=.cache
